#!/bin/bash
# Raindrop CLI - Holocron Launcher
LOG_FILE="$HOME/.raindrop/holocron/holocron.log"
SERVER_SCRIPT="$HOME/.raindrop/holocron/server.py"
# Use graillm_venv python
PYTHON_EXEC="$HOME/graillm_venv/bin/python"

if pgrep -f "server.py" > /dev/null; then
    echo "Holocron is already running."
    exit 0
fi

echo "Igniting Holocron Core..."
nohup $PYTHON_EXEC $SERVER_SCRIPT > $LOG_FILE 2>&1 &
echo "Holocron Daemon launched. PID: $!"
echo "Logs: $LOG_FILE"
